funcprot(0); 
clear; clc; clf; 

// --- Physical Constants ---
e = 3.795; 
m = 0.511e6; // Using standard 'e' for scientific notation (0.511 MeV)
hc = 1973;   // Renamed from 'h' to avoid conflict with the step size later

c1 = -2*m*e*e/(hc*hc); 
c2 = -2*m/(hc*hc); 

// --- Grid Setup ---
ri = 0.00001; 
rf = 8; 
ui = 0.0; 
dui = 1; 
dr = 0.05;  // FIXED: Renamed from 'h' to 'dr' (step size)
r = ri:dr:rf; 

a1 = 3; a2 = 5; a3 = 7; 

// ==========================================
// Case 1: a1 = 3
// ==========================================
E101 = -9; 
E102 = -10; 

function du = f1(r, u, E) 
    du(1) = u(2); // FIXED: Added semicolon
    du(2) = c1*u(1)*(1/r)*exp(-r/a1) + c2*E*u(1); 
endfunction 

for i = 1:100 
    u101 = ode([ui; dui], ri, r, list(f1, E101)); 
    u102 = ode([ui; dui], ri, r, list(f1, E102)); 
    E103 = (E101 + E102)/2; 
    u103 = ode([ui; dui], ri, r, list(f1, E103)); 
    
    // FIXED: Moved 'then' to the same line. Using $ for last element.
    if (u101(1,$) * u103(1,$)) < 0 then  
        E102 = E103; 
    else 
        E101 = E103; 
    end 
end 
disp("Ground State energy (eV) for a=" + string(a1) + " is: " + string(E103)); 

// ==========================================
// Case 2: a2 = 5
// ==========================================
E201 = -10; 
E202 = -11; 

function du = f2(r, u, E) 
    du(1) = u(2); 
    du(2) = c1*u(1)*(1/r)*exp(-r/a2) + c2*E*u(1); 
endfunction  

for i = 1:100  
    u201 = ode([ui; dui], ri, r, list(f2, E201));  
    u202 = ode([ui; dui], ri, r, list(f2, E202)); 
    E203 = (E201 + E202)/2;  
    u203 = ode([ui; dui], ri, r, list(f2, E203)); 
    
    if (u201(1,$) * u203(1,$)) < 0 then 
        E202 = E203; 
    else 
        E201 = E203; 
    end 
end 
disp("Ground State energy (eV) for a=" + string(a2) + " is: " + string(E203)); 

// ==========================================
// Case 3: a3 = 7
// ==========================================
E301 = -11; 
E302 = -12; 

function du = f3(r, u, E) 
    du(1) = u(2);  
    du(2) = c1*u(1)*(1/r)*exp(-r/a3) + c2*E*u(1); 
endfunction 

for i = 1:100 
    u301 = ode([ui; dui], ri, r, list(f3, E301)); 
    u302 = ode([ui; dui], ri, r, list(f3, E302));  
    E303 = (E301 + E302)/2; 
    u303 = ode([ui; dui], ri, r, list(f3, E303)); 
    
    if (u301(1,$) * u303(1,$)) < 0 then  
        E302 = E303; 
    else     
        E301 = E303; 
    end 
end 
disp("Ground State energy (eV) for a=" + string(a3) + " is: " + string(E303)); 

// ==========================================
// Plotting
// ==========================================
zm = zeros(1, length(r)); // Zero line for visual reference

// FIXED: Added standard color letters (r, b, g, k) so markers render clearly
plot(r, u103(1,:), 'r-*', r, u203(1,:), 'b-+', r, u303(1,:), 'g->', r, zm, 'k--'); 

a = gca();  
a.thickness = 2; 
a.box = "on"; 

title("Energy Eigenfunctions", "fontsize", 4); 
xlabel("r in Angstrom", "fontsize", 3); 
ylabel("Wave Function", "fontsize", 3); 

// Cleaned up legend dynamically
legend(["a=3A, E=" + string(E103) + "eV", ...
        "a=5A, E=" + string(E203) + "eV", ...
        "a=7A, E=" + string(E303) + "eV"], 1);
